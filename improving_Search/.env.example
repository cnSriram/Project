# MongoDB connection string (Atlas)
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/

# IGDB API Credentials (From Twitch Developer Console)
IGDB_CLIENT_ID=your_client_id
IGDB_CLIENT_SECRET=your_client_secret

# Optional: Legacy Access Token (Service will auto-refresh if valid secret is provided)
IGDB_ACCESS_TOKEN=your_access_token
